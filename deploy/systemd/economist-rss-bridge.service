[Unit]
Description=Economist RSS Bridge
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=trendradar
Group=trendradar
WorkingDirectory=/opt/trendradar
Environment=HOME=/var/lib/trendradar
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/bin/python3 /opt/trendradar/scripts/economist_rss_bridge.py --host 127.0.0.1 --port 4556 --ttl 900
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
