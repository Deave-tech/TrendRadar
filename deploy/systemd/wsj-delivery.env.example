# Install as /etc/trendradar/wsj-delivery.env, owned by root:root and mode 0600.
BPC_API_TOKEN=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_RECEIVE_ID=
FEISHU_RECEIVE_ID_TYPE=chat_id

BPC_BASE_URL=http://127.0.0.1:8080
WSJ_FEED_URL=http://127.0.0.1:4555/wsj-cn.xml
# Both workers must use this one database.  The process lock and document cap
# are therefore global across WSJ + Economist, rather than 300 per publisher.
NEWS_DELIVERY_DB=/var/lib/trendradar/wsj-delivery.db
FEISHU_DOC_URL_PREFIX=https://feishu.cn/docx
WSJ_MAX_ITEMS_PER_RUN=20
WSJ_MAX_DRAIN_SECONDS=5400
# Only Docx tokens created and recorded by the shared outbox are counted/deleted.
NEWS_MAX_CLOUD_DOCUMENTS=300

# Opt in only after the Feishu app has docs:document.media:upload and a test
# document has passed create/upload/replace/share verification.
WSJ_INCLUDE_IMAGES=false
WSJ_IMAGE_ALLOWED_HOSTS=images.wsj.net
WSJ_IMAGE_MAX_BYTES=10485760
WSJ_IMAGE_MAX_COUNT=8
WSJ_IMAGE_MAX_REDIRECTS=3
WSJ_IMAGE_TIMEOUT=20
WSJ_IMAGE_MAX_PIXELS=40000000

ECONOMIST_FEED_URL=http://127.0.0.1:4556/economist.xml
ECONOMIST_MAX_ITEMS_PER_RUN=20
ECONOMIST_MAX_DRAIN_SECONDS=5400
ECONOMIST_INCLUDE_IMAGES=true
ECONOMIST_IMAGE_ALLOWED_HOSTS=www.economist.com
ECONOMIST_IMAGE_MAX_BYTES=10485760
ECONOMIST_IMAGE_MAX_COUNT=20
ECONOMIST_IMAGE_MAX_REDIRECTS=3
ECONOMIST_IMAGE_TIMEOUT=20
ECONOMIST_IMAGE_MAX_PIXELS=40000000
